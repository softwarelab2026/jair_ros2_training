{
    "name": "Devcontainer",
    "build": {
        "context": "..",
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "pijar.ros-snippets",
                "Ranch-Hand-Robotics.rde-ros-2"
            ]
        }
    },
    "mounts":[
        "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind",
    ],
    "containerEnv": {
        "DISPLAY": "${localEnv:DISPLAY}",
        "QT_X11_NO_MITSHM": "1",
    },
    "postCreateCommand": ".devcontainer/setup_devcontainer.sh",
    // "remoteUser": "root"
}
