    "version": "0.2.0",
    "tasks": [
        {
            "label": "Run",
            "type": "shell",
            "command": "source install/setup.bash && ros2 launch run.py",
            "options": {
                "cwd": "${workspaceFolder}/src",
                "shell": {
                    "executable": "/bin/bash",
                    "args": ["-c"]
