{
    "version": "0.2.0",
    "tasks": [
        {
            "label": "Run Turtlesim",
            "type": "shell",
            "command": "rm -rf build install log && colcon build --symlink-install && source install/setup.bash && ros2 launch run.py",
            "options": {
                "cwd": "${workspaceFolder}/src",
                "shell": {
                    "executable": "/bin/bash",
                    "args": [
                        "-c"
                    ]
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "test",
            "type": "shell",
            "command": "colcon build --symlink-install && clear && python3 -m pytest",
            "options": {
                "cwd": "${workspaceFolder}/src/jair_turtlesim",
                "shell": {
                    "executable": "/bin/bash",
                    "args": [
                        "-c"
                    ]
                }
            }
        },
        {
            "label": "pre-commit",
            "type": "shell",
            "command": "pre-commit run --all-files",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "/bin/bash",
                    "args": [
                        "-c"
                    ]
                }
            },
            "problemMatcher": []
        }
    ]
}
